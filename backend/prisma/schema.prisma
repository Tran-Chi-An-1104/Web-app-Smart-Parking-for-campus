// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid()) // HCMUT ID
  rfidCard      String?   @unique              // Thẻ định danh
  name          String
  email         String    @unique
  role          UserRole
  department    String?   // Đồng bộ từ DATACORE
  sessions      ParkingSession[]
  createdAt     DateTime  @default(now())
}

model ParkingZone {
  id            String    @id @default(cuid())
  name          String    // VD: Khu A, Tầng hầm
  capacity      Int
  type          ZoneType
  slots         ParkingSlot[]
}

model ParkingSlot {
  id            String    @id @default(cuid())
  zoneId        String
  zone          ParkingZone @relation(fields: [zoneId], references: [id])
  sensorId      String    @unique
  status        SlotStatus @default(AVAILABLE)
  lastUpdated   DateTime  @updatedAt
}

model ParkingSession {
  id            String    @id @default(cuid())
  userId        String?   // Khách vãng lai thì null
  user          User?     @relation(fields: [userId], references: [id])
  temporaryId   String?   // Mã vé tạm
  entryTime     DateTime  @default(now())
  exitTime      DateTime?
  status        SessionStatus @default(ACTIVE)
  fee           Float?
  paymentStatus PaymentStatus @default(PENDING)
}

enum UserRole {
  LEARNER
  FACULTY
  STAFF
  VISITOR
  OPERATOR
  ADMIN
}

enum ZoneType { MOTORBIKE, CAR }
enum SlotStatus { AVAILABLE, OCCUPIED, MAINTENANCE }
enum SessionStatus { ACTIVE, COMPLETED }
enum PaymentStatus { PENDING, PAID, FAILED }